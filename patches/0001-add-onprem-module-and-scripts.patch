+  console.log("\n=== Packaging complete ===")
+  console.log(`Bundle directory: ${BUNDLE_DIR}`)
+  console.log(`Tarball: dist/${TARBALL_NAME}`)
+}
+
+main().catch((err) => {
+  console.error("Error:", err)
+  process.exit(1)
+})
