+
+async function main() {
+  console.log("=== OpenCode Onprem Bundle Packager ===")
+
+  const depsExist = await fs.stat(DEPS_DIR).catch(() => null)
+  if (!depsExist) {
+    console.error(`Error: Dependencies not found at ${DEPS_DIR}`)
