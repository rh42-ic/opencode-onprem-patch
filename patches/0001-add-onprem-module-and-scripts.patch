+    clangdVersion,
+    rustAnalyzerVersion,
+    zlsVersion,
+    luaLsVersion,
+    terraformLsVersion,
+    texlabVersion,
+    tinymistVersion,
+    treeSitterWasm,
+    npmVersions
+  )
+
+  console.log("\n=== Download complete ===")
+  console.log(`Dependencies saved to: ${DEPS_DIR}`)
+}
+
+main().catch((err) => {
+  console.error("Error:", err)
