From 31c736eb6c0642ee177224dac3fc7cfd7145ee73 Mon Sep 17 00:00:00 2001
From: test <test@test.com>
Date: Mon, 6 Apr 2026 00:06:06 +0800
Subject: [PATCH 5/5] onprem: add offline plugin detection in plugin/shared.ts

---
 packages/opencode/src/plugin/shared.ts | 10 ++++++++++
 script/package-onprem-bundle.ts        |  2 +-
 2 files changed, 11 insertions(+), 1 deletion(-)

diff --git a/packages/opencode/src/plugin/shared.ts b/packages/opencode/src/plugin/shared.ts
index f92520d..a8eca0c 100644
--- a/packages/opencode/src/plugin/shared.ts
+++ b/packages/opencode/src/plugin/shared.ts
@@ -4,6 +4,7 @@ import semver from "semver"
 import { Npm } from "@/npm"
 import { Filesystem } from "@/util/filesystem"
 import { isRecord } from "@/util/record"
+import { Onprem } from "../onprem"
 
 // Old npm package names for plugins that are now built-in
 export const DEPRECATED_PLUGIN_PACKAGES = ["opencode-openai-codex-auth", "opencode-copilot-auth"]
@@ -192,6 +193,15 @@ export async function checkPluginCompatibility(target: string, opencodeVersion:
 
 export async function resolvePluginTarget(spec: string, parsed = parsePluginSpecifier(spec)) {
   if (isPathPluginSpec(spec)) return resolvePathPluginTarget(spec)
+
+  // onprem-fork: check offline plugins directory first
+  if (Onprem.isEnabled()) {
+    const pluginPath = Onprem.resolvePlugin(parsed.pkg)
+    if (pluginPath && await Onprem.pluginExists(parsed.pkg)) {
+      return pluginPath
+    }
+  }
+
   const result = await Npm.add(parsed.pkg + "@" + parsed.version)
   return result.directory
 }
diff --git a/script/package-onprem-bundle.ts b/script/package-onprem-bundle.ts
index 297ba63..8388f06 100644
--- a/script/package-onprem-bundle.ts
+++ b/script/package-onprem-bundle.ts
@@ -359,7 +359,7 @@ async function createTarball(platform: string, variant: BuildVariant): Promise<v
   await fs.unlink(tarballPath).catch(() => {})
 
   const args = isWindows 
-    ? ["7z", "a", "-t7z", "-mx=1", "-mmt=on", TARBALL_NAME, BUNDLE_DIR]
+    ? ["7z", "a", "-t7z", "-mmt=on", TARBALL_NAME, BUNDLE_DIR]
     : ["tar", "--zstd", "-cf", TARBALL_NAME, BUNDLE_DIR]
 
   const proc = Bun.spawn(args, {
