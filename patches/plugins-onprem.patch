From 74cd0d051bbf111ef3850ab4934690061a622697 Mon Sep 17 00:00:00 2001
From: RH42-IC <chensy.ic@foxmail.com>
Date: Tue, 31 Mar 2026 13:35:01 +0000
Subject: [PATCH 5/5] onprem: add offline plugin detection in BunProc.install()

---
 packages/opencode/src/bun/index.ts | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/packages/opencode/src/bun/index.ts b/packages/opencode/src/bun/index.ts
index dbdf5a2..24463cd 100644
--- a/packages/opencode/src/bun/index.ts
+++ b/packages/opencode/src/bun/index.ts
@@ -8,6 +8,7 @@ import { Lock } from "../util/lock"
 import { PackageRegistry } from "./registry"
 import { online, proxied } from "@/util/network"
 import { Process } from "../util/process"
+import { Onprem } from "../onprem"
 
 export namespace BunProc {
   const log = Log.create({ service: "bun" })
@@ -51,6 +52,15 @@ export namespace BunProc {
   )
 
   export async function install(pkg: string, version = "latest") {
+    // onprem-fork: check offline plugins directory first
+    if (Onprem.isEnabled()) {
+      const pluginPath = Onprem.resolvePlugin(pkg)
+      if (pluginPath && await Onprem.pluginExists(pkg)) {
+        log.info("using onprem plugin", { pkg, path: pluginPath })
+        return pluginPath
+      }
+    }
+
     // Use lock to ensure only one install at a time
     using _ = await Lock.write("bun-install")
 
